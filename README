# Структура каталогов и файлов в целевой системе

В каталоге root создается дерево каталогов с файлами которые при постинсталяционной настройке копируются в целевую систему

root
├── etc
│   ├── afick.conf
│   ├── ansible
│   │   ├── ansible.cfg
│   │   └── hosts
│   ├── audit
│   │   └── rules.d
│   │       └── astra-custom.rules
│   ├── logrotate.d
│   │   └── passwd
│   ├── syslog-ng
│   │   └── conf.d
│   │       ├── afick-events.conf
│   │       ├── astra-custom.conf
│   │       ├── astra-events.conf
│   │       ├── audit-events.conf
│   │       └── rebus-events.conf
│   ├── systemd
│   │   └── system
│   │       └── afick.service
│   └── tmpfiles.d
│       └── syslog-ng.conf
└── usr
    ├── local
    │   ├── bin
    │   │   ├── notify-sender
    │   │   ├── userctl
    │   │   └── xmpp-sender
    │   └── lib
    │       └── python2.7
    │           └── dist-packages
    │               └── custom_syslog_ng_classes.py
    └── share
        └── applications
            └── notify-sender.desktop


afick.service юнит средства регламентного контроля целостности afick
postinst.sh постинсталляционный скрипт
notify-sender.desktop ярлык на который создаются симлинки для автозапуска программы notify-sender (если от этого варианта уведомлений отказываемся, то удалить)

Для нормальной работы с событиями auditd необходимо удалить файл
/etc/audit/rules.d/10-parsec.rules /etc/audit/rules.d/10-parsec.rules.bak
иначе все события поступают с ключом parsec-p и их невозможно нормально фильтровать по назначенным кастомным ключам!

Создание архива в инструментальной системе
cd root; tar --owner=root --group=root -czvf ../postinst.tar.gz *

Разархивирование на целевой системе
tar -xzvf postinst.tar.gz -C /

Изменение максимального уровня целостности
sudo sed -i 's/sysmaxlev=3/sysmaxlev=2/g' /usr/sbin/pdp-init-fs

Изменить целостность содержимого командой:
sudo pdpl-file -R -r -s 2:63:0 /
после чего перезагрузить АРМ и проверить целостность командой
sudo pdp-ls -Ma /

Управление пользователями
Показать список пользователей
userctl list # Кастомный скрипт
Создание пользователя
userctl addoperator user_name password
userctl addnachsmen user_name password
userctl addadmsec user_name password
Блокирование/разблокирование
userctl lock user_name
passwd -l user_name # Можно сделать alias lockuser='passwd -l'
userctl unlock user_name
passwd -u user_name # Можно сделать alias unlockuser='passwd -u'
Удаление
deluser user_name --remove-home
Смена пароля
userctl chpass user_name password
echo "user_name:password" | chpasswd

Настройки САВЗ Dr.Web (клиент) - все в карантин:
drweb-ctl cfset LinuxGUI.OnKnownVirus Quarantine
drweb-ctl cfset LinuxGUI.OnIncurable Quarantine
drweb-ctl cfset LinuxGUI.OnSuspicious Quarantine
drweb-ctl cfset LinuxGUI.OnAdware Quarantine
drweb-ctl cfset LinuxGUI.OnDialers Quarantine
drweb-ctl cfset LinuxGUI.OnJokes Quarantine
drweb-ctl cfset LinuxGUI.OnRiskware Quarantine
drweb-ctl cfset LinuxGUI.OnHacktools Quarantine
drweb-ctl cfset LinuxSpider.OnKnownVirus Quarantine
drweb-ctl cfset LinuxSpider.OnIncurable Quarantine
drweb-ctl cfset LinuxSpider.OnSuspicious Quarantine
drweb-ctl cfset LinuxSpider.OnAdware Quarantine
drweb-ctl cfset LinuxSpider.OnDialers Quarantine
drweb-ctl cfset LinuxSpider.OnJokes Quarantine
drweb-ctl cfset LinuxSpider.OnRiskware Quarantine
drweb-ctl cfset LinuxSpider.OnHacktools Quarantine
