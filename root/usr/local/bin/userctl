#!/usr/bin/env bash

usage() {
    cat << EOF
Использование: userctl КОМАНДА [ПОЛЬЗОВАТЕЛЬ [ПАРОЛЬ]]
Выполняет операции с учетными записями пользователей
КОМАНДЫ:
  addadmsec   создать ПОЛЬЗОВАТЕЛЯ с правами администратора безопасности"
  addnachsmen создать ПОЛЬЗОВАТЕЛЯ с правами начальника смены"
  addoperator создать ПОЛЬЗОВАТЕЛЯ с правами оператора"
  status      вывести статус ПОЛЬЗОВАТЕЛЯ
  lock        заблокировать ПОЛЬЗОВАТЕЛЯ"
  unlock      разблокировать ПОЛЬЗОВАТЕЛЯ"
  delete      удалить ПОЛЬЗОВАТЕЛЯ"
  list        вывести список пользователей"
  help        показать эту справку"
EOF
}

if [ $(basename $0) == "userctl" ]; then
    # Если программа вызвана непосредственно,
    # то требуемое действие должно задаваться в первом аргументе
    if [ $# -eq 0 ]; then
        echo "userctl: не задана команда"
        usage
        exit 1
    fi
    command=$1
    shift
else
    # Если программа вызвана через симлинк,
    # то требуемое действие соответствует имени симлинка
    command=$(basename $0)
fi

if [ $command == "--help" ] || [ $command == "help" ]; then
    usage
    exit 0
fi

# Остальные команды требуют прав суперпользователя,
# поэтому запрашиваем пароль здесь, чтобы sudo больше не требовал пароля
sudo true
if [ $? -ne 0 ]; then
    exit
fi

# Получить список групп в которые по умолчанию добавляются вновь создаваемые пользователи
# NB! По умолчанию в список включены группы fuse и veston-launch, которых нет в системе!
# Их необходимо удалить из параметра EXTRA_GROUPS в файле /etc/adduser.conf
secondary_groups=$(grep ^EXTRA_GROUPS /etc/adduser.conf | cut -d'"' -f2 | tr ' ' ',')

# Вывести список несистемных пользователей и выйти
if [ $command == "list" ]; then
    echo "Локальные пользователи:"
    # Диапазон uid используемый командой  useradd задается значениями
    # UID_MIN и UID_MAX в файле /etc/login.defs (по дефолту от 1000 до 60000)
    getent passwd | sort | awk -F: '{if ($3>=1000 && $3<60000) {
                                         system("groups " $1);
                                         system("sudo pdpl-user " $1);
                                         system("echo")
                                         }}'
    # Если есть команда ald-admin, то вывести список доменных пользователей
    sudo which ald-admin 1> /dev/null
    if [ $? -eq 0 ]; then
        echo "Доменные пользователи:"
        sudo ald-admin user-list | sort | awk '{system ("groups "$1);
                                                system("sudo pdpl-user " $1);
                                                system("echo")}'
    fi
    exit 0
fi

# Проверить наличие обязательного для остальных команд имени пользователя
if [ $# -eq 0 ]; then
    echo "userctl: не задан пользователь"
    usage
    exit 3
fi

case $command in
addoperator)
    primary_group="operators"
    sudo useradd -g $primary_group -G $secondary_groups -s /bin/bash -p $(openssl passwd -1 $2) -m $1
    # Возвращает 9, если пользователь $1 уже существует
    if [ $? -ne 0 ]; then
      exit $?
    fi
    sudo pdpl-user -l 0:2 -i 0 -c 0:0 $1
    ;;
addnachsmen)
    primary_group="nachsmens"
    sudo useradd -g $primary_group -G $secondary_groups -s /bin/bash -p $(openssl passwd -1 $2) -m $1
    if [ $? -ne 0 ]; then
      exit $?
    fi
    sudo pdpl-user -l 0:2 -i 0 -c 0:0 $1
    ;;
addadmsec)
    primary_group="astra-admin"
    sudo useradd -g $primary_group -G $secondary_groups,astra-console,adm -s /bin/bash -p $(openssl passwd -1 $2) -m $1
    if [ $? -ne 0 ]; then
      exit $?
    fi
    sudo pdpl-user -l 0:0 -i 63 -c 0:0 $1
    # Генерация ssh-ключей для созданого администратора безопасности
    sudo mkdir -p /home/$1/.ssh
    sudo ssh-keygen -f /home/$1/.ssh/id_rsa -q -N ""
    sudo chown -R $1:$primary_group /home/$1/.ssh
    # Далее нужно скопировать открытый ключ на все управляемые СВТ
    ;;
status)
    passwd --status $1
    ;;
del|delete)
    read -e -p "Удалить учетную запись $1 [y/N]" yesno
    if [ "$yesno" == "y" ] || [ "$yesno" == "Y" ]; then
        # При необходимости сначала можно бэкапить /etc/passwd
        sudo deluser $1 --remove-home --quiet
    fi
    ;;
lock|block)
    # Блокировка пароля учетной записи, оставляет возможность подключения по ssh
    sudo passwd -l $1 1>/dev/null
    # Блокировка учетной записи
    # usermod -L $1
    ;;
unlock|unblock)
    # Разблокировка пароля учетной записи
    sudo passwd -u $1 1>/dev/null
    # Разблокировка учетной записи
    # usermod -U $1
    ;;
*)
    echo "userctl: неизвестная команда $command"
    usage
    exit 2
    ;;
esac
